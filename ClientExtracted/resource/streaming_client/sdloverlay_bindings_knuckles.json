{
   "bindings" : {
      "/actions/virtualgamepad" : {
         "haptics" : [
            {
               "output" : "/actions/virtualgamepad/out/haptic_right",
               "path" : "/user/hand/right/output/haptic"
            },
            {
               "output" : "/actions/virtualgamepad/out/haptic_left",
               "path" : "/user/hand/left/output/haptic"
            }
         ],
         "sources" : [
            {
               "inputs" : {
                  "pull" : {
                     "output" : "/actions/virtualgamepad/in/trigger_left"
                  }
               },
               "mode" : "trigger",
               "path" : "/user/hand/left/input/trigger"
            },
            {
               "inputs" : {
                  "pull" : {
                     "output" : "/actions/virtualgamepad/in/trigger_right"
                  }
               },
               "mode" : "trigger",
               "path" : "/user/hand/right/input/trigger"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/back"
                  },
                  "position" : {
                     "output" : "/actions/virtualgamepad/in/stick_left"
                  }
               },
               "mode" : "joystick",
               "path" : "/user/hand/left/input/thumbstick"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/start"
                  },
                  "position" : {
                     "output" : "/actions/virtualgamepad/in/stick_right"
                  }
               },
               "mode" : "joystick",
               "path" : "/user/hand/right/input/thumbstick"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/a"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/right/input/a"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/b"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/right/input/b"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/x"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/left/input/a"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/y"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/left/input/b"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/shoulder_left"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/left/input/grip"
            },
            {
               "inputs" : {
                  "click" : {
                     "output" : "/actions/virtualgamepad/in/shoulder_right"
                  }
               },
               "mode" : "button",
               "path" : "/user/hand/right/input/grip"
            }
         ]
      }
   },
   "controller_type" : "knuckles",
   "description" : "SDL Virtual Gamepad bindings for Index Controllers",
   "name" : "SDL Virtual Gamepad bindings for Index"
}
